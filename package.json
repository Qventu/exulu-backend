{
  "name": "@exulu/backend",
  "author": "Qventu Bv.",
  "version": "0.3.13-development",
  "main": "./dist/index.js",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "setup-python": "./bin/setup-python.cjs"
  },
  "homepage": "https://exulu.com",
  "engines": {
    "node": "22.18.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Qventu/exulu-backend.git"
  },
  "scripts": {
    "preinstall": "node -e \"if (process.version !== 'v22.18.0') { console.error('❌ Wrong Node.js version. Expected v22.18.0, got ' + process.version); process.exit(1); }\"",
    "postinstall": "node scripts/postinstall.cjs",
    "build": "tsup",
    "dev": "npm link && tsup --watch",
    "prepare": "husky",
    "semantic-release": "semantic-release",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:errors": "eslint src --ext .ts --quiet",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "audit:fix": "npm audit fix",
    "cpd": "jscpd src --reporters console",
    "cpd:report": "jscpd src --reporters console,html",
    "cpd:view": "serve cpd-report/html -l 3001",
    "python:setup": "cd ee/python && ./setup.sh",
    "python:install": "source ee/python/.venv/bin/activate && pip install -r ee/python/requirements.txt",
    "python:validate": "source ee/python/.venv/bin/activate && python -c 'import docling; import transformers; print(\"✓ Python environment is working correctly\")'",
    "python:clean": "rm -rf ee/python/.venv ee/python/__pycache__ ee/python/**/__pycache__ ee/python/**/*.pyc",
    "python:rebuild": "npm run python:clean && npm run python:setup"
  },
  "keywords": [
    "exulu"
  ],
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "latest",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/graphql-type-json": "^0.3.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "conventional-changelog-atom": "^5.0.0",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jscpd": "^4.0.8",
    "prettier": "^3.4.2",
    "semantic-release": "24.2.9",
    "serve": "^14.2.6",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/cerebras": "^2.0.29",
    "@ai-sdk/google-vertex": "^4.0.28",
    "@ai-sdk/openai": "^3.0.18",
    "@anthropic-ai/sdk": "^0.56.0",
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.0.0",
    "@aws-sdk/client-s3": "^3.338.0",
    "@aws-sdk/client-sts": "^3.338.0",
    "@aws-sdk/s3-request-presigner": "^3.338.0",
    "@llamaindex/liteparse": "^1.0.1",
    "@mistralai/mistralai": "^2.1.1",
    "@modelcontextprotocol/sdk": "^1.14.0",
    "@opentelemetry/api-logs": "^0.203.0",
    "@opentelemetry/auto-instrumentations-node": "^0.62.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.203.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.203.0",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-logs": "^0.203.0",
    "@opentelemetry/sdk-node": "^0.203.0",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "@opentelemetry/winston-transport": "^0.14.1",
    "@perplexity-ai/perplexity_ai": "^0.25.0",
    "ai": "^6.0.49",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "bullmq": "^5.48.1",
    "bullmq-otel": "^1.0.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-validator": "^1.4.0",
    "crypto-js": "^4.2.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-http-proxy": "^2.1.2",
    "franc": "^6.2.0",
    "graphql": "^16.11.0",
    "graphql-tools": "^9.0.18",
    "graphql-type-json": "^0.3.2",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.0.10",
    "json-schema-to-zod": "^2.6.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "link": "^2.1.1",
    "mammoth": "^1.11.0",
    "natural": "^8.1.0",
    "officeparser": "^5.2.2",
    "openai": "^5.21.0",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.2",
    "pg": "^8.16.3",
    "pgvector": "^0.2.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "tiktoken": "^1.0.21",
    "turndown": "^7.2.2",
    "uuid": "^11.1.0",
    "wink-nlp": "^2.4.0",
    "winston": "^3.17.0",
    "word-extractor": "^1.0.4",
    "zod": "^3.25.76",
    "zod-from-json-schema": "^0.5.2",
    "zod-to-json-schema": "^3.25.1",
    "zodex": "^0.18.2"
  },
  "files": [
    "dist",
    "ee",
    "bin",
    "scripts/postinstall.cjs"
  ]
}
